{
	"kind": "collectionType",
	"collectionName": "posts",
	"info": {
		"singularName": "post",
		"pluralName": "posts",
		"displayName": "Post"
	},
	"options": {
		"draftAndPublish": true
	},
	"pluginOptions": {},
	"attributes": {
		"title": {
			"type": "string",
			"minLength": 4,
			"maxLength": 150,
			"required": true,
			"unique": true
		},
		"slug": {
			"type": "uid",
			"targetField": "title",
			"required": true
		},
		"cover": {
			"type": "media",
			"multiple": true,
			"allowedTypes": ["images"]
		},
		"authors": {
			"type": "relation",
			"relation": "oneToMany",
			"target": "admin::user"
		},
		"tags": {
			"type": "relation",
			"relation": "oneToMany",
			"target": "api::tag.tag"
		},
		"seo": {
			"type": "component",
			"component": "seo.seo-information",
			"repeatable": false
		},
		"content": {
			"type": "richtext",
			"required": true
		}
	}
}
